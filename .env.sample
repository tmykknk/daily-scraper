SPREADSHEET_ID=""
DRIVE_FOLDER_ID=""

# マイドライブへ保存する場合は、この行をコメントアウトせず oauth のまま使う
# 共有ドライブ + サービスアカウントで運用する場合だけ service_account に変更する
GOOGLE_AUTH_MODE=oauth

# GOOGLE_AUTH_MODE=oauth のときに使用する。oauth運用ではコメントアウトしない
GOOGLE_OAUTH_TOKEN_PATH=token.json

SCRAPER_BROWSER_CHANNEL=chrome
SCRAPER_HEADLESS=true
